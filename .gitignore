### Ruby.gitignore

# Existing Ruby ignores
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/
/config/settings.yaml

# Used by dotenv library to load environment variables.
.env

# Mac specific ignores
.DS_Store
.AppleDouble
.LSOverride
._*

# Application specific
/config/settings.yaml  # Already included but good to keep
*.inetloc             # Ignore local Mac URL files
/projects/            # Ignore generated project folders if they're in the repo
.env                  # For any environment variables (already commented)

# IDE/Editor specific
.vscode/
.idea/
*.swp
*~

## Documentation cache and generated files:
/.yardoc/
/_yardoc/
/doc/
/rdoc/

## Environment normalization:
/.bundle/
/vendor/bundle
/lib/bundler/man/

# Ruby environment managers (some already included)
.ruby-version
.ruby-gemset
.rbenv-version
.rvmrc
.tool-versions

# Dependencies
/vendor/bundle/
Gemfile.lock         # Consider tracking this for applications

# for a library or gem, you might want to ignore these files since the code is
# intended to run in multiple environments; otherwise, check them in:
# Gemfile.lock
# .ruby-version
# .ruby-gemset
# .tool-versions

# unless supporting rvm < 1.11.0 or doing something fancy, ignore this:
.rvmrc



